<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Slide up slowly -->
    <translate
        android:fromYDelta="60"
        android:toYDelta="0"
        android:duration="2000" />

    <!-- Fade in slowly -->
    <alpha
        android:fromAlpha="0"
        android:toAlpha="1"
        android:duration="2000" />

</set>
