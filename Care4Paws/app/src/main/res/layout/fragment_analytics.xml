<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F6FB"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ================= HEADER ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analytics Dashboard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This dashboard shows total reports submitted in the system and their current status distribution (Rescued vs Pending)."
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="20dp"/>


        <!-- ================= REPORT OVERVIEW CARD ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports Overview"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginBottom="12dp"/>

            <!-- Bar Chart -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChar"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                tools:ignore="MissingClass"/>

            <!-- Legend Explanation -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔵 Total Reports   •   🟢 Rescued   •   🔴 Pending"
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginTop="10dp"/>

        </LinearLayout>


        <!-- ================= STATUS DISTRIBUTION CARD ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Distribution (%)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginBottom="12dp"/>

            <!-- Pie Chart -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChar"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                tools:ignore="MissingClass"/>

            <!-- Legend -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🟢 Rescued   •   🔴 Pending"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>